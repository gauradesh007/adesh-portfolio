---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config/site";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.image,
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE.url);
const socialImageUrl = new URL(image, SITE.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.author,
  url: SITE.url,
  jobTitle: "Enterprise Integration Architect",
  description: SITE.description,
  image: socialImageUrl.href,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Miami",
    addressRegion: "FL",
    addressCountry: "US",
  },
  sameAs: [
    "https://www.linkedin.com/in/adesh-gaur/",
    "https://github.com/gauradesh007",
  ],
  knowsAbout: [
    "Enterprise Integration",
    "Boomi",
    "Healthcare Integration",
    "Healthcare EDI",
    "HIPAA X12",
    "Enterprise APIs",
    "Agentic AI",
    "Retrieval-Augmented Generation",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Document -->
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <!-- Search metadata -->
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta
      name="robots"
      content={noindex ? "noindex,nofollow" : "index,follow"}
    />

    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Browser appearance -->
    <meta name="theme-color" content="#165fb8" />
    <meta name="color-scheme" content="light" />

    <!-- Favicons -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      type="image/x-icon"
      href="/favicon.ico"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={SITE.author} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={socialImageUrl.href} />
    <meta
      property="og:image:alt"
      content="Adesh Gaur, Enterprise Integration Architect"
    />

    <!-- Twitter / X -->
    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content={description}
    />
    <meta
      name="twitter:image"
      content={socialImageUrl.href}
    />
    <meta
      name="twitter:image:alt"
      content="Adesh Gaur, Enterprise Integration Architect"
    />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>

  <body>
    <Header />

    <slot />

    <Footer />
  </body>
</html>