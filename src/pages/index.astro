---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="Adesh Gaur | Enterprise Integration Architect"
  description="Enterprise Integration Architect specializing in Boomi, Healthcare Integration and EDI, enterprise APIs, technical leadership, and AI-powered solutions."
>
  <main>
    <Hero />

    <!-- Boomi Expertise -->
    <section id="boomi" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Boomi Expertise</p>

          <h2>
            Architecture, development, APIs, events, and enterprise delivery.
          </h2>

          <p class="section-intro">
            My Boomi experience covers the complete integration lifecycle—from
            requirements analysis and architecture through development,
            testing, deployment, monitoring, estimation, and technical
            leadership.
          </p>
        </div>

        <div class="card-grid">
          <article class="card expertise-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">01</span>
              <h3>Integration Architecture</h3>
            </div>

            <p>
              Design scalable integration landscapes using reusable processes,
              canonical models, connector strategies, enterprise patterns, and
              clearly defined operational controls.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">02</span>
              <h3>API Design &amp; Management</h3>
            </div>

            <p>
              Design governed enterprise APIs with consistent contracts,
              lifecycle management, security controls, reusable services, and
              operational visibility.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">03</span>
              <h3>Event-Driven Integration</h3>
            </div>

            <p>
              Apply asynchronous messaging, Event Streams, retries, dead-letter
              handling, monitoring, and resilient processing for distributed
              enterprise ecosystems.
            </p>
          </article>
        </div>

        <div class="section-actions">
        <a class="button button-primary" href="/boomi">
          Explore Boomi Expertise
        </a>
      </div>
      </div>
    </section>

    <!-- Healthcare Expertise -->
    <section id="edi" class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Healthcare Expertise</p>

          <h2>Healthcare Integration &amp; EDI</h2>

          <p class="section-intro">
            Over the past seven years, I have specialized in designing and
            delivering healthcare payer integration solutions using Boomi,
            HIPAA X12 EDI, enterprise APIs, and intelligent automation. My
            experience spans enrollment, claims, remittance, premium payments,
            validation, transformation, and operational support.
          </p>
        </div>

        <div class="card-grid healthcare-grid">
          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">834</span>
              <h3>Enrollment</h3>
            </div>

            <p>
              Member enrollment, maintenance, eligibility updates,
              reconciliation, validation, and downstream integration.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">837</span>
              <h3>Claims</h3>
            </div>

            <p>
              Professional and Institutional claims processing, validation,
              routing, transformation, and payer integration.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">835</span>
              <h3>Remittance</h3>
            </div>

            <p>
              Electronic remittance advice, reconciliation, payment
              integration, and financial processing.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">820</span>
              <h3>Premium Payments</h3>
            </div>

            <p>
              Premium billing, payment processing, enterprise integration, and
              financial data exchange.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">API</span>
              <h3>Healthcare APIs</h3>
            </div>

            <p>
              REST APIs, FHIR integration, secure data exchange, and
              interoperability across enterprise systems.
            </p>
          </article>

          <article class="card expertise-card">
            <div class="card-heading">
              <span class="transaction-number" aria-hidden="true">AI</span>
              <h3>Validation &amp; Automation</h3>
            </div>

            <p>
              HIPAA X12 validation, mapping, routing, exception handling, and
              AI-assisted operational support.
            </p>
          </article>
        </div>

        <div class="tech-stack" aria-label="Healthcare technologies">
          <span>HIPAA X12</span>
          <span>Boomi</span>
          <span>FHIR</span>
          <span>REST APIs</span>
          <span>Validation</span>
          <span>Automation</span>
          <span>AI</span>
        </div>

        <div class="section-actions">
          <a href="/healthcare" class="button button-primary">
            Explore Healthcare Expertise
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section id="products" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Featured Products</p>

          <h2>
            Products that combine enterprise integration architecture and AI.
          </h2>

          <p class="section-intro">
            These products apply practical AI to enterprise integration,
            architecture, healthcare EDI, knowledge retrieval, and operational
            problem solving.
          </p>
        </div>

        <div class="product-grid">
          <article class="card product-card product-card-featured">
            <div class="product-card-top">
              <span class="badge">Live</span>
              <span class="product-type">Enterprise AI Product</span>
            </div>

            <h3>Boomi AI Solution Architect</h3>

            <p>
              An AI-powered architecture assistant combining deterministic
              engineering tools, enterprise knowledge retrieval, structured
              architecture review, and local LLM reasoning.
            </p>

            <div class="product-tags" aria-label="Product technologies">
              <span>Boomi</span>
              <span>Agentic AI</span>
              <span>RAG</span>
              <span>Ollama</span>
            </div>

            <a
              class="text-link"
              href="https://boomi-ai.gaurcloud.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open live application
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card product-card">
            <div class="product-card-top">
              <span class="badge badge-development">In Development</span>
              <span class="product-type">Healthcare AI Product</span>
            </div>

            <h3>Healthcare EDI Intelligence Agent</h3>

            <p>
              A privacy-conscious solution combining deterministic HIPAA EDI
              validation with Agentic AI and retrieval-augmented explanations.
            </p>

            <div class="product-tags" aria-label="Product technologies">
              <span>HIPAA X12</span>
              <span>Pyx12</span>
              <span>ChromaDB</span>
              <span>Agentic AI</span>
            </div>

            <a class="text-link" href="/products">
              Explore product details
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card product-card">
            <div class="product-card-top">
              <span class="badge badge-learning">Learning Platform</span>
              <span class="product-type">Engineering Journey</span>
            </div>

            <h3>Agentic AI Engineering Journey</h3>

            <p>
              A structured hands-on program covering agents, tools, RAG,
              orchestration, local models, deployment, evaluation, and
              enterprise use cases.
            </p>

            <div class="product-tags" aria-label="Learning technologies">
              <span>Python</span>
              <span>Ollama</span>
              <span>RAG</span>
              <span>Agentic AI</span>
            </div>

            <a
              class="text-link"
              href="https://github.com/gauradesh007/agentic-ai-30-days"
              target="_blank"
              rel="noopener noreferrer"
            >
              View learning repository
              <span aria-hidden="true">→</span>
            </a>
          </article>
        </div>

        <div class="section-actions">
          <a href="/products" class="button button-primary">
            Explore All Products
          </a>
        </div>
      </div>
    </section>

    <!-- Professional Journey -->
    <section id="journey" class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Professional Journey</p>

          <h2>
            More than two decades of enterprise engineering and integration
            leadership.
          </h2>

          <p class="section-intro">
            My professional journey has evolved from Java and database engineering
            into enterprise integration architecture, Boomi leadership, healthcare
            interoperability, APIs, and practical AI engineering.
          </p>
        </div>

        <div class="journey-preview-grid">
          <article class="card journey-preview-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">01</span>
              <h3>Enterprise Engineering Foundation</h3>
            </div>

            <p>
              Java, databases, SQL, application integration, and enterprise
              software engineering established the technical foundation of my
              career.
            </p>
          </article>

          <article class="card journey-preview-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">02</span>
              <h3>Integration Architecture</h3>
            </div>

            <p>
              Middleware architecture, reusable integration patterns, APIs, data
              transformation, Boomi delivery, and operational reliability.
            </p>
          </article>

          <article class="card journey-preview-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">03</span>
              <h3>Healthcare Integration &amp; EDI</h3>
            </div>

            <p>
              Healthcare payer integration, HIPAA X12 transactions, validation,
              routing, reconciliation, interoperability, and production support.
            </p>
          </article>

          <article class="card journey-preview-card">
            <div class="card-heading">
              <span class="marker" aria-hidden="true">04</span>
              <h3>AI-powered Enterprise Solutions</h3>
            </div>

            <p>
              Agentic AI, RAG, local models, deterministic engineering tools, and
              intelligent automation for enterprise integration challenges.
            </p>
          </article>
        </div>

        <div class="section-actions">
          <a class="button button-primary" href="/journey">
            Explore My Professional Journey
          </a>
        </div>
      </div>
    </section>

        <!-- Verified Credentials -->
    <section id="credentials" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Verified Credentials</p>

          <h2>
            Verified Boomi and AI credentials supporting practical expertise.
          </h2>

          <p class="section-intro">
            My certifications validate experience across integration
            architecture, API management, integration development, Event
            Streams, and AI engineering.
          </p>
        </div>

        <div class="credential-grid">
          <article class="card credential-card">
            <span class="credential-provider">Boomi</span>

            <h3>Associate Integration Architect</h3>

            <a
              class="text-link"
              href="https://verify.skilljar.com/c/26tug8cnyeto"
              target="_blank"
              rel="noopener noreferrer"
            >
              Verify credential
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card credential-card">
            <span class="credential-provider">Boomi</span>

            <h3>Professional API Management</h3>

            <a
              class="text-link"
              href="https://verify.skilljar.com/c/ybyh6zr6fiqk"
              target="_blank"
              rel="noopener noreferrer"
            >
              Verify credential
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card credential-card">
            <span class="credential-provider">Boomi</span>

            <h3>Professional Integration Developer</h3>

            <a
              class="text-link"
              href="https://verify.skilljar.com/c/bpkaj6i4tmcs"
              target="_blank"
              rel="noopener noreferrer"
            >
              Verify credential
              <span aria-hidden="true">→</span>
            </a>
          </article>
        </div>

        <div class="section-actions">
          <a href="/credentials" class="button button-primary">
            View All Credentials
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .section-heading {
    max-width: 880px;
  }

  .section-heading h2 {
    max-width: 24ch;
  }

  .card-heading {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .card-heading h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .expertise-card {
    min-width: 0;
  }

  .expertise-card p {
    line-height: 1.7;
  }

  .transaction-number {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    min-width: 2.8rem;
    height: 2.5rem;
    padding-inline: 0.55rem;
    border: 1px solid rgba(22, 95, 184, 0.14);
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1;
  }

  .healthcare-grid {
    margin-top: 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .product-card-featured {
    border-color: rgba(22, 95, 184, 0.35);
    background:
      linear-gradient(
        145deg,
        rgba(220, 236, 255, 0.52),
        var(--color-surface) 58%
      );
  }

  .product-card-top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .product-type {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .product-card h3 {
    margin-bottom: 0.8rem;
  }

  .product-card > p {
    flex-grow: 1;
    line-height: 1.7;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.3rem 0;
  }

  .product-tags span {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .badge-development {
    background: #fff4db;
    color: #906100;
  }

  .badge-learning {
    background: #ede9fe;
    color: #6842b8;
  }

  .journey-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
  }

  .journey-preview-card {
  min-width: 0;
  }

  .journey-preview-card p {
  margin: 0;
  color: var(--color-text-body);
  line-height: 1.7;
  }

.credential-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .credential-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .credential-card h3 {
    flex-grow: 1;
    margin: 1rem 0 1.5rem;
  }

  .credential-provider {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

    @media (max-width: 900px) {
    .product-grid,
    .credential-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .journey-preview-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .product-grid,
    .credential-grid {
      grid-template-columns: 1fr;
    }

    .card-heading {
      align-items: flex-start;
    }
  }
</style>