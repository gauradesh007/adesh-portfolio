---
import BaseLayout from "../layouts/BaseLayout.astro";

const boomiCredentials = [
  {
    title: "Associate Integration Architect",
    description:
      "Integration architecture, solution patterns, platform design, governance, and enterprise delivery.",
    verification: "https://verify.skilljar.com/c/26tug8cnyeto",
  },
  {
    title: "Associate Integration Developer",
    description:
      "Boomi process development, profiles, mappings, connectors, deployment, and operational fundamentals.",
    verification: "https://verify.skilljar.com/c/93ixnxz8yxfs",
  },
  {
    title: "Professional Integration Developer",
    description:
      "Advanced Boomi development, reusable components, error handling, performance, and production-ready delivery.",
    verification: "https://verify.skilljar.com/c/bpkaj6i4tmcs",
  },
  {
    title: "Professional API Design",
    description:
      "Enterprise API contracts, reusable services, lifecycle design, security, and integration standards.",
    verification: "https://verify.skilljar.com/c/3kb5gakwxdf5",
  },
  {
    title: "Professional API Management",
    description:
      "API lifecycle management, governance, security controls, monitoring, and operational ownership.",
    verification: "https://verify.skilljar.com/c/ybyh6zr6fiqk",
  },
  {
    title: "Associate Event Streams",
    description:
      "Event-driven integration, asynchronous messaging, streaming patterns, reliability, and operational support.",
    verification: "https://verify.skilljar.com/c/33hyn7p8yzys",
  },
];

const aiCredentials = [
  {
    title: "GenAI Academy: Yellow Belt Level 2 for Developers",
    provider: "Enterprise GenAI Academy",
    description:
      "Developer-focused generative AI concepts, solution patterns, responsible implementation, and enterprise use cases.",
    verification:
      "https://nttdataservices.digitalbadges.skillsoft.com/cf420e6a-fcec-43d2-93a5-8ee06a1b6ba4",
  },
  {
    title: "IBM AI Developer",
    provider: "IBM",
    description:
      "Applied AI development using Python, machine learning services, generative AI, APIs, and practical application patterns.",
    verification:
      "https://www.coursera.org/account/accomplishments/specialization/certificate/7GI4I3AGA5H2",
  },
  {
    title: "Generative AI for Data Scientists",
    provider: "IBM",
    description:
      "Generative AI foundations for data workflows, prompt engineering, language models, analytics, and responsible AI.",
    verification:
      "https://www.coursera.org/account/accomplishments/specialization/32Y7PKVNZGJJ",
  },
  {
    title: "Introduction to Generative AI",
    provider: "Google Cloud",
    description:
      "Foundational understanding of generative AI, model capabilities, common applications, and enterprise opportunities.",
    verification:
      "https://www.coursera.org/account/accomplishments/verify/Q7XW5YE1FZLW",
  },
  {
    title: "Introduction to Large Language Models",
    provider: "Google Cloud",
    description:
      "Core LLM concepts, prompting, tuning approaches, model behavior, limitations, and practical applications.",
    verification:
      "https://www.coursera.org/account/accomplishments/verify/45GERCZAEU11",
  },
  {
    title: "Introduction to Generative AI Learning Path",
    provider: "Google Cloud",
    description:
      "Structured learning across generative AI, large language models, responsible AI, and practical solution concepts.",
    verification:
      "https://www.coursera.org/account/accomplishments/specialization/certificate/N4QWFDLCC2ZK",
  },
];
---

<BaseLayout
  title="Credentials | Adesh Gaur"
  description="Verified Boomi and AI credentials supporting enterprise integration architecture, API management, Event Streams, development, and intelligent automation."
>
  <main>
    <!-- Page Hero -->
    <section class="page-hero credentials-hero">
      <div class="container page-hero-grid">
        <div class="page-hero-content">
          <p class="eyebrow">Verified Credentials</p>

          <h1 class="hero-title-wide">
            Verified credentials across integration and AI.
          </h1>

          <p class="hero-lead">
            Continuous learning across integration architecture, APIs, Event
            Streams, development, AI engineering, and intelligent automation.
          </p>

          <p class="hero-copy">
            Certifications independently verify technical knowledge, but their
            greatest value comes from applying that knowledge to architecture,
            delivery, troubleshooting, modernization, and production
            operations.
          </p>

          <div class="button-row">
            <a class="button button-primary" href="#boomi-credentials">
              View Credentials
            </a>

            <a class="button button-secondary" href="/contact">
              Request Full CV
            </a>
          </div>
        </div>

        <aside
          class="page-summary-panel credentials-summary"
          aria-labelledby="credentials-title"
        >
          <p id="credentials-title" class="panel-label">
            Credential Focus
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">06</span>

              <div>
                <strong>Boomi Credentials</strong>
                <small>
                  Architecture, development, APIs, and Event Streams
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">06</span>

              <div>
                <strong>AI Credentials</strong>
                <small>
                  Generative AI, LLMs, development, and enterprise applications
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">20+</span>

              <div>
                <strong>Practical Experience</strong>
                <small>
                  Enterprise engineering, architecture, and integration delivery
                </small>
              </div>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Boomi Credentials -->
    <section id="boomi-credentials" class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Boomi Credentials</p>

          <h2>Verified expertise across the Boomi platform.</h2>

          <p class="section-intro">
            These credentials validate knowledge across architecture,
            development, API design and management, Event Streams, governance,
            and enterprise integration delivery.
          </p>
        </div>

        <div class="credential-grid">
          {
            boomiCredentials.map((credential) => (
              <article class="card credential-card">
                <span class="credential-provider">Boomi</span>

                <h3>{credential.title}</h3>

                <p>{credential.description}</p>

                <a
                  class="text-link"
                  href={credential.verification}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Verify credential
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- AI Credentials -->
    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Artificial Intelligence</p>

          <h2>Continuous learning in practical enterprise AI.</h2>

          <p class="section-intro">
            These credentials support my work with generative AI, large
            language models, Agentic AI, knowledge retrieval, intelligent
            automation, and enterprise solution development.
          </p>
        </div>

        <div class="credential-grid">
          {
            aiCredentials.map((credential) => (
              <article class="card credential-card">
                <span class="credential-provider">{credential.provider}</span>

                <h3>{credential.title}</h3>

                <p>{credential.description}</p>

                <a
                  class="text-link"
                  href={credential.verification}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Verify credential
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="section page-cta">
      <div class="container page-cta-inner">
        <div>
          <p class="eyebrow">Professional Profile</p>

          <h2>
            Need a complete summary of my experience and credentials?
          </h2>

          <p>
            Use the contact page to request my latest professional CV or
            discuss enterprise integration, Boomi, healthcare, APIs, or AI
            opportunities.
          </p>
        </div>

        <div class="button-row">
          <a class="button button-primary" href="/contact">
            Request My CV
          </a>

          <a class="button button-secondary" href="/journey">
            View My Journey
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .panel-label {
    margin: 0 0 1.25rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    max-width: 880px;
  }

  .section-heading h2 {
    max-width: 24ch;
  }

  .credential-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .credential-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .credential-provider {
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .credential-card h3 {
    margin: 1rem 0 0.75rem;
  }

  .credential-card p {
    flex-grow: 1;
    margin: 0 0 1.5rem;
    color: var(--color-text-body);
    line-height: 1.7;
  }

  .credential-card .text-link {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .credential-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .credential-grid {
      grid-template-columns: 1fr;
    }
  }
</style>