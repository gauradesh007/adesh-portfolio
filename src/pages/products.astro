---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products | Adesh Gaur"
  description="Enterprise products combining Boomi architecture, Healthcare Integration and EDI, Agentic AI, RAG, local models, and intelligent automation."
>
  <main>
    <!-- Page Hero -->
    <section class="page-hero products-hero">
      <div class="container page-hero-grid">
        <div class="page-hero-content">
          <p class="eyebrow">Enterprise Products</p>

          <h1 class="hero-title-wide">
            Products built for enterprise integration challenges.
          </h1>

          <p class="hero-lead">
            Combining deterministic engineering, integration architecture,
            enterprise knowledge, and practical AI.
          </p>

          <p class="hero-copy">
            I design products that apply enterprise integration patterns,
            deterministic tools, knowledge retrieval, and AI-assisted reasoning
            to architecture, healthcare EDI, operational support, and technical
            decision-making.
          </p>

          <div class="button-row">
            <a class="button button-primary" href="#product-portfolio">
              Explore Products
            </a>

            <a class="button button-secondary" href="/contact">
              Discuss a Product
            </a>
          </div>
        </div>

        <aside
          class="page-summary-panel portfolio-summary"
          aria-labelledby="portfolio-summary-title"
        >
          <p id="portfolio-summary-title" class="panel-label">
            Product Portfolio
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">01</span>

              <div>
                <strong>Boomi AI Solution Architect</strong>
                <small>
                  Live architecture assistant for Boomi-oriented solution
                  design
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">02</span>

              <div>
                <strong>Healthcare EDI Intelligence Agent</strong>
                <small>
                  HIPAA EDI validation, explanation, and corrective guidance
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">03</span>

              <div>
                <strong>Agentic AI Engineering Journey</strong>
                <small>
                  Hands-on AI agent development and experimentation platform
                </small>
              </div>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Product Portfolio -->
    <section id="product-portfolio" class="section section-muted">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Product Portfolio</p>

          <h2>
            Enterprise products designed around real integration challenges.
          </h2>

          <p class="section-intro">
            Each product combines domain knowledge, deterministic engineering,
            and AI-assisted capabilities while keeping reliability, privacy,
            and practical business value at the center.
          </p>
        </div>

        <div class="product-overview-grid">
          <article class="card product-overview-card featured-product">
            <div class="product-card-top">
              <span class="badge">Live</span>
              <span class="product-category">Enterprise AI Product</span>
            </div>

            <h3>Boomi AI Solution Architect</h3>

            <p>
              AI-assisted Boomi architecture recommendations grounded in
              enterprise integration patterns, deterministic tools, knowledge
              retrieval, and structured solution review.
            </p>

            <div class="product-tags" aria-label="Boomi product technologies">
              <span>Boomi</span>
              <span>Agentic AI</span>
              <span>RAG</span>
              <span>Ollama</span>
            </div>

            <a
              class="text-link"
              href="https://boomi-ai.gaurcloud.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open live application
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card product-overview-card">
            <div class="product-card-top">
              <span class="badge badge-development">In Development</span>
              <span class="product-category">Healthcare AI Product</span>
            </div>

            <h3>Healthcare EDI Intelligence Agent</h3>

            <p>
              Deterministic HIPAA X12 validation combined with AI-assisted
              explanations, root-cause context, and corrective recommendations.
            </p>

            <div
              class="product-tags"
              aria-label="Healthcare product technologies"
            >
              <span>HIPAA X12</span>
              <span>Pyx12</span>
              <span>ChromaDB</span>
              <span>Agentic AI</span>
            </div>

            <a class="text-link" href="/healthcare">
              Explore healthcare expertise
              <span aria-hidden="true">→</span>
            </a>
          </article>

          <article class="card product-overview-card">
            <div class="product-card-top">
              <span class="badge badge-learning">Learning Platform</span>
              <span class="product-category">Engineering Journey</span>
            </div>

            <h3>Agentic AI Engineering Journey</h3>

            <p>
              A structured learning and experimentation platform covering
              agents, tools, RAG, orchestration, local models, evaluation, and
              deployment.
            </p>

            <div
              class="product-tags"
              aria-label="Learning platform technologies"
            >
              <span>Python</span>
              <span>Ollama</span>
              <span>RAG</span>
              <span>Agentic AI</span>
            </div>

            <a
              class="text-link"
              href="https://github.com/gauradesh007/agentic-ai-30-days"
              target="_blank"
              rel="noopener noreferrer"
            >
              View learning repository
              <span aria-hidden="true">→</span>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="section page-cta">
      <div class="container page-cta-inner">
        <div>
          <p class="eyebrow">Product Collaboration</p>

          <h2>
            Interested in enterprise integration products or AI-assisted
            architecture solutions?
          </h2>

          <p>
            Connect with me to discuss product ideas, integration challenges,
            Healthcare EDI intelligence, Boomi architecture, or practical
            enterprise AI applications.
          </p>
        </div>

        <div class="button-row">
          <a class="button button-primary" href="/contact">
            Discuss a Product
          </a>

          <a
            class="button button-secondary"
            href="https://boomi-ai.gaurcloud.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open Live Product
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .panel-label {
    margin: 0 0 1.25rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    max-width: 880px;
  }

  .section-heading h2 {
    max-width: 24ch;
  }

  .product-overview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .product-overview-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .featured-product {
    border-color: rgba(22, 95, 184, 0.35);
    background:
      linear-gradient(
        145deg,
        rgba(220, 236, 255, 0.52),
        var(--color-surface) 58%
      );
  }

  .product-card-top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .product-category {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .product-overview-card h3 {
    margin-bottom: 0.8rem;
  }

  .product-overview-card > p {
    flex-grow: 1;
    line-height: 1.7;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.35rem 0;
  }

  .badge-development {
    background: #fff4db;
    color: #906100;
  }

  .badge-learning {
    background: #ede9fe;
    color: #6842b8;
  }

  @media (max-width: 900px) {
    .product-overview-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .product-overview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>