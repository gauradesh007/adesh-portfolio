---
import BaseLayout from "../layouts/BaseLayout.astro";
const web3FormsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
---

<BaseLayout
  title="Contact | Adesh Gaur"
  description="Contact Adesh Gaur to discuss Enterprise Integration, Boomi architecture, Healthcare Integration and EDI, enterprise APIs, technical leadership, and AI-powered solutions."
>
  <main>
    <section class="page-hero contact-hero">
      <div class="container page-hero-grid">
        <div class="page-hero-content">
          <p class="eyebrow">Professional Contact</p>

          <h1>Let&rsquo;s discuss enterprise integration.</h1>

          <p class="hero-lead">
            Connect with me about Boomi architecture, Healthcare Integration
            &amp; EDI, APIs, modernization, technical leadership, or AI-powered
            enterprise solutions.
          </p>

          <p class="hero-copy">
            Share a brief description of your opportunity, architecture
            challenge, collaboration idea, or request for my professional CV.
            I will respond using the contact information you provide.
          </p>

          <p class="hero-location">
            Based in Miami, Florida, USA, delivering enterprise integration solutions for global organizations.
          </p>
        </div>

        
        <aside class="page-summary-panel contact-options" aria-labelledby="contact-options-title" >
          <p id="contact-options-title" class="panel-label">
            Contact Options
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">01</span>
              <div>
                <strong>Email</strong>
                <a href="mailto:adesh@gaurcloud.com">
                  adesh@gaurcloud.com
                </a>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">02</span>
              <div>
                <strong>LinkedIn</strong>
                <a
                  href="https://www.linkedin.com/in/adesh-gaur/"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Professional profile
                </a>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">03</span>
              <div>
                <strong>GitHub</strong>
                <a
                  href="https://github.com/gauradesh007"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Technical repositories
                </a>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">04</span>
              <div>
                <strong>Location</strong>
                 <small>
                  <span class="location-value">
                    Miami, Florida, USA
                  </span>

                  <span class="location-timezone">
                    • Eastern Time (ET)
                  </span>
                </small>
              </div>
            </li>

          </ul>
        </aside>
      </div>
    </section>

    <section class="section section-muted">
      <div class="container contact-layout">
        <div>
          <p class="eyebrow">Send a Message</p>

          <h2>Tell me what you would like to discuss.</h2>

          <p class="section-intro">
            Share a few details about your opportunity, architecture challenge,
            collaboration idea, or request for my professional CV.
          </p>

          <form
            id="contact-form"
            class="contact-form"
            method="POST"
          >
            <input
              type="hidden"
              name="access_key"
              value={web3FormsAccessKey}
            />

            <input
              type="hidden"
              name="subject"
              value="New message from adesh.gaurcloud.com"
            />

            <input
              type="hidden"
              name="from_name"
              value="Adesh Gaur Portfolio"
            />

            <input
              type="checkbox"
              name="botcheck"
              class="hidden-field"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="form-grid">
              <label>
                <span>Name</span>

                <input
                  type="text"
                  name="name"
                  placeholder="Your name"
                  autocomplete="name"
                  required
                />
              </label>

              <label>
                <span>Email</span>

                <input
                  type="email"
                  name="email"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                />
              </label>
            </div>

            <label>
              <span>Topic</span>

              <select name="topic" required>
                <option value="">Select a topic</option>
                <option value="integration">Enterprise Integration</option>
                <option value="boomi">Boomi Architecture</option>
                <option value="healthcare">
                  Healthcare Integration &amp; EDI
                </option>
                <option value="products">Products &amp; AI Solutions</option>
                <option value="cv">Request CV</option>
                <option value="other">Other</option>
              </select>
            </label>

            <label>
              <span>Message</span>

              <textarea
                name="message"
                rows="7"
                placeholder="Tell me briefly about your request..."
                required
              ></textarea>
            </label>

            <button
              id="contact-submit"
              class="button button-primary"
              type="submit"
            >
              Send Message
            </button>

            <p
              id="form-status"
              class="form-status"
              role="status"
              aria-live="polite"
            ></p>
          </form>
        </div>

        <aside class="contact-guidance">
          <p class="panel-label">Useful Information</p>

          <div>
            <h3>Professional Inquiries</h3>
            <p>
              Include the role, project context, location or remote expectations,
              and the primary technologies involved.
            </p>
          </div>

          <div>
            <h3>Architecture Discussions</h3>
            <p>
              Briefly describe the integration landscape, business challenge,
              platforms, and desired outcome.
            </p>
          </div>

          <div>
            <h3>Requesting My CV</h3>
            <p>
              Mention the opportunity or reason for the request so I can share
              the most relevant and current version.
            </p>
          </div>
        </aside>
      </div>
    </section>
  </main>

<script>
  const form =
    document.querySelector<HTMLFormElement>("#contact-form");

  const submitButton =
    document.querySelector<HTMLButtonElement>("#contact-submit");

  const statusMessage =
    document.querySelector<HTMLParagraphElement>("#form-status");

  if (form && submitButton && statusMessage) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
      statusMessage.textContent = "";
      statusMessage.className = "form-status";

      try {
        const response = await fetch(
          "https://api.web3forms.com/submit",
          {
            method: "POST",
            body: new FormData(form),
          },
        );

        const responseText = await response.text();

        if (!responseText) {
          throw new Error(
            "The contact service returned an empty response.",
          );
        }

        const result = JSON.parse(responseText);

        if (!response.ok || !result.success) {
          throw new Error(
            result.message || "Your message could not be sent.",
          );
        }

        statusMessage.textContent =
          "Thank you. Your message has been sent successfully.";

        statusMessage.classList.add("form-status-success");
        form.reset();
      } catch (error) {
        console.error("Contact form submission failed:", error);

        statusMessage.textContent =
          error instanceof Error
            ? error.message
            : "Your message could not be sent.";

        statusMessage.classList.add("form-status-error");
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "Send Message";
      }
    });
  }
</script>
</BaseLayout>

<style>

  .panel-label {
    margin: 0 0 1.25rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .contact-hero {
    padding: 6rem 0 5rem;
    background:
      radial-gradient(
        circle at 86% 12%,
        rgba(22, 95, 184, 0.12),
        transparent 31rem
      ),
      linear-gradient(180deg, #ffffff, #f4f8fc);
  }

  .contact-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.72fr);
    gap: 4rem;
    align-items: center;
  }

  .contact-hero h1 {
    max-width: 13ch;
    margin: 0.75rem 0 1.25rem;
    font-size: clamp(3rem, 5.4vw, 5rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .hero-lead {
    max-width: 44rem;
    color: var(--color-text);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 650;
  }

  .hero-copy {
    max-width: 48rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .contact-options,
  .contact-guidance {
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
  }

  .contact-options ul {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-options li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-options li:last-child {
    border-bottom: 0;
  }

  .contact-options li > div {
    display: grid;
    gap: 0.3rem;
  }

  .contact-options a,
  .contact-guidance a {
    color: var(--color-primary);
    font-weight: 700;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.7fr);
    gap: 4rem;
    align-items: start;
  }

  .contact-form {
    display: grid;
    gap: 1.25rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .contact-form label {
    display: grid;
    gap: 0.5rem;
  }

  .contact-form label > span {
    color: var(--color-text);
    font-weight: 700;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: #ffffff;
    color: var(--color-text);
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--color-primary);
    outline: 3px solid rgba(22, 95, 184, 0.12);
  }

  .contact-form .button {
    justify-self: start;
  }

  .contact-guidance {
    display: grid;
    gap: 1.5rem;
  }

  .contact-guidance div {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-guidance div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .contact-guidance h3 {
    margin-bottom: 0.5rem;
  }

  .contact-guidance p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .contact-hero-grid,
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .contact-form {
      padding: 1.25rem;
    }
  }

  .form-status {
  min-height: 1.5rem;
  margin-top: .5rem;
  font-size: 0.9rem;
  font-weight: 700;
}

.form-status-success {
  color: #18794e;
}

.form-status-error {
  color: #b42318;
}

.contact-form .button:disabled {
  opacity: 0.7;
  cursor: wait;
}

.hidden-field {
  position: absolute;
  left: -9999px;
  width: 1px;
  height: 1px;
  overflow: hidden;
}

.hero-location {
  max-width: 48rem;
  margin: 1rem 0 0;
  color: var(--color-text-muted);
  font-size: 0.95rem;
  line-height: 1.7;
}

.location-value{
    color:var(--color-text);
    font-weight:600;
}

.location-timezone{
    color:var(--color-text-muted);
}

.contact-options small {
    color: var(--color-text-muted);
    line-height: 1.6;
}


</style>