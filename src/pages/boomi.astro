---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Boomi Expertise | Adesh Gaur"
  description="Boomi architecture, integration development, API management, Event Streams, monitoring, estimation, and enterprise delivery expertise."
>
  <main>
    <!-- Page Hero -->
    <section class="page-hero boomi-hero">
      <div class="container page-hero-grid">
        <div class="page-hero-content">
          <p class="eyebrow">Boomi Expertise</p>

          <h1 class="hero-title-wide">
            Enterprise Boomi architecture from requirements through production.
          </h1>

          <p class="hero-lead">
            Designing scalable, reusable, and operationally reliable integration
            solutions across the complete Boomi delivery lifecycle.
          </p>

          <p class="hero-copy">
            My Boomi experience spans solution architecture, integration
            development, API design and management, Event Streams, connector
            strategy, healthcare integration, estimation, monitoring, and
            technical delivery leadership.
          </p>

          <div class="button-row">
            <a class="button button-primary" href="/products">
              Explore Products
            </a>

            <a class="button button-secondary" href="/credentials">
              View Credentials
            </a>
          </div>
        </div>

        <aside class="page-summary-panel boomi-summary" aria-labelledby="boomi-focus-title">
          <p id="boomi-focus-title" class="panel-label">
            Boomi Delivery Focus
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">01</span>

              <div>
                <strong>Solution Architecture</strong>
                <small>
                  Requirements, patterns, canonical models, and platform design
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">02</span>

              <div>
                <strong>Integration Engineering</strong>
                <small>
                  Processes, mappings, connectors, validation, and reuse
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">03</span>

              <div>
                <strong>APIs &amp; Event Streams</strong>
                <small>
                  API lifecycle, asynchronous messaging, retries, and resilience
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">04</span>

              <div>
                <strong>Delivery Leadership</strong>
                <small>
                  Estimation, architecture reviews, governance, and operations
                </small>
              </div>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Core Capabilities -->
    <section class="section section-muted">
      <div class="container">
        <p class="eyebrow">Core Capabilities</p>

        <h2>
          Architecture, engineering, governance, and operational reliability.
        </h2>

        <div class="capability-grid">
          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">01</span>
              <h3>Solution Architecture</h3>
            </div>

            <p>
              Translate business requirements into scalable integration
              landscapes, reusable process designs, canonical data models, and
              clearly defined system responsibilities.
            </p>
          </article>

          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">02</span>
              <h3>Integration Development</h3>
            </div>

            <p>
              Design Boomi processes, profiles, mappings, connectors,
              validations, reusable subprocesses, and deployment-ready
              integration components.
            </p>
          </article>

          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">03</span>
              <h3>API Design &amp; Management</h3>
            </div>

            <p>
              Establish consistent API contracts, reusable services, security
              controls, lifecycle governance, observability, and operational
              ownership.
            </p>
          </article>

          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">04</span>
              <h3>Event-Driven Integration</h3>
            </div>

            <p>
              Apply asynchronous messaging, Event Streams, retry strategies,
              dead-letter handling, and resilient processing for distributed
              systems.
            </p>
          </article>

          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">05</span>
              <h3>Monitoring &amp; Reliability</h3>
            </div>

            <p>
              Design logging, business identifiers, alerts, error routing,
              retry policies, process reporting, and production-support
              procedures.
            </p>
          </article>

          <article class="card capability-card">
            <div class="capability-header">
              <span class="capability-number" aria-hidden="true">06</span>
              <h3>Estimation &amp; Leadership</h3>
            </div>

            <p>
              Support discovery, complexity assessment, effort estimation,
              architecture reviews, delivery planning, and technical team
              guidance.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Architecture Approach -->
    <section class="section">
      <div class="container split-layout">
        <div class="approach-heading">
          <p class="eyebrow">Architecture Approach</p>

          <h2>How I approach enterprise integration design.</h2>

          <p>
            Sustainable integration architecture balances business outcomes,
            engineering standards, operational reliability, and long-term
            maintainability.
          </p>
        </div>

        <div class="principles">
          <article>
            <span class="principle-number" aria-hidden="true">01</span>

            <div>
              <h3>Business requirements first</h3>

              <p>
                Architecture begins with business outcomes, data ownership,
                service expectations, constraints, and operational
                responsibilities.
              </p>
            </div>
          </article>

          <article>
            <span class="principle-number" aria-hidden="true">02</span>

            <div>
              <h3>Reusable before duplicated</h3>

              <p>
                Shared services, standard error handling, common profiles, and
                reusable subprocesses reduce maintenance and improve
                consistency.
              </p>
            </div>
          </article>

          <article>
            <span class="principle-number" aria-hidden="true">03</span>

            <div>
              <h3>Deterministic before AI</h3>

              <p>
                Validation, routing, security, and business rules remain
                deterministic. AI is introduced where explanation, assistance,
                or intelligent recommendations provide measurable value.
              </p>
            </div>
          </article>

          <article>
            <span class="principle-number" aria-hidden="true">04</span>

            <div>
              <h3>Operations are part of architecture</h3>

              <p>
                Monitoring, supportability, recovery, auditability, and failure
                handling are designed from the beginning rather than added
                later.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Related Product -->
    <section class="section section-muted">
      <div class="container product-section">
        <div>
          <p class="eyebrow">Related Product</p>

          <h2>Boomi AI Solution Architect</h2>

          <p class="page-intro">
            A live AI-powered product combining deterministic architecture
            tools, enterprise knowledge retrieval, structured review, and
            local LLM reasoning to generate Boomi-oriented solution
            recommendations.
          </p>

          <div class="product-tags" aria-label="Product technologies">
            <span>Boomi</span>
            <span>Agentic AI</span>
            <span>RAG</span>
            <span>Ollama</span>
            <span>ChromaDB</span>
            <span>Python</span>
          </div>

          <div class="button-row">
            <a
              class="button button-primary"
              href="https://boomi-ai.gaurcloud.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open Live Application
            </a>

            <a
              class="button button-secondary"
              href="https://github.com/gauradesh007/boomi-ai-solution-architect"
              target="_blank"
              rel="noopener noreferrer"
            >
              View GitHub
            </a>
          </div>
        </div>

        <aside class="product-summary" aria-labelledby="product-focus-title">
          <p id="product-focus-title" class="panel-label">
            Product Focus
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">01</span>
              <span>Structured Boomi architecture recommendations</span>
            </li>

            <li>
              <span class="marker" aria-hidden="true">02</span>
              <span>Enterprise integration pattern guidance</span>
            </li>

            <li>
              <span class="marker" aria-hidden="true">03</span>
              <span>Knowledge retrieval using RAG</span>
            </li>

            <li>
              <span class="marker" aria-hidden="true">04</span>
              <span>Local-model reasoning and data privacy</span>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section page-cta">
      <div class="container page-cta-inner">
        <div>
          <p class="eyebrow">Let&rsquo;s Connect</p>

          <h2>
            Need support with Boomi architecture, APIs, Event Streams, or
            enterprise integration delivery?
          </h2>

          <p>
            I am interested in solution architecture, technical leadership,
            integration modernization, estimation, governance, and
            AI-assisted Boomi opportunities.
          </p>
        </div>

        <div class="button-row">
          <a class="button button-primary" href="/contact">
            Start a Conversation
          </a>

          <a class="button button-secondary" href="/products">
            Explore Products
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>

  .page-intro {
    max-width: 820px;
    margin: 1.5rem 0 2rem;
    color: var(--color-text-body);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 2.25rem;
  }

  .capability-card {
    min-width: 0;
  }

  .capability-header {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .capability-header h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .capability-number,
  .principle-number {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(22, 95, 184, 0.14);
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    line-height: 1;
  }

  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 4rem;
    align-items: start;
  }

  .approach-heading {
    position: sticky;
    top: 6rem;
  }

  .approach-heading p:last-child {
    max-width: 34rem;
    margin-bottom: 0;
    color: var(--color-text-body);
    line-height: 1.75;
  }

  .principles {
    display: grid;
  }

  .principles article {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .principles article:first-child {
    padding-top: 0;
  }

  .principles article:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .principles h3 {
    margin: 0 0 0.55rem;
  }

  .principles p {
    margin: 0;
    color: var(--color-text-body);
    line-height: 1.7;
  }

  .product-section {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.7fr);
    gap: 4rem;
    align-items: center;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 0 0 2rem;
  }

  .product-tags span {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .product-summary {
    padding: 1.7rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .panel-label {
    margin: 0 0 1.25rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-summary ul {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-summary li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-body);
    line-height: 1.5;
  }

  .product-summary li:first-child {
    padding-top: 0;
  }

  .product-summary li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  @media (max-width: 900px) {
    .page-hero {
      padding: 4.5rem 0 4rem;
    }

    .capability-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .split-layout,
    .product-section {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .approach-heading {
      position: static;
    }

    .product-summary {
      max-width: 42rem;
    }
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 3.75rem 0 3.5rem;
    }

    .page-intro {
      font-size: 1rem;
    }

    .capability-grid {
      grid-template-columns: 1fr;
    }

    .capability-header {
      align-items: flex-start;
    }

    .product-summary {
      padding: 1.3rem;
    }
  }



</style>