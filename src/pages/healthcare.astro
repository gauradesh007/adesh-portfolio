---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Healthcare Integration & EDI | Adesh Gaur";

const pageDescription =
  "Healthcare payer integration expertise spanning HIPAA X12 EDI, Boomi, enterprise APIs, validation, automation, and AI-assisted healthcare solutions.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <!-- Page Hero -->
    <section class="healthcare-hero">
      <div class="container healthcare-hero-grid">
        <div class="healthcare-hero-content">
          <p class="eyebrow">Healthcare Expertise</p>

          <h1>Healthcare Integration &amp; EDI</h1>

          <p class="hero-lead">
            Designing secure, scalable, and standards-based integration
            solutions for complex healthcare payer ecosystems.
          </p>

          <p class="hero-copy">
            Over the past seven years, I have specialized in healthcare payer
            integration using Boomi, HIPAA X12 EDI, enterprise APIs, and
            intelligent automation. My experience spans enrollment, claims,
            remittance, premium payments, validation, transformation, routing,
            exception management, and operational support.
          </p>

          <div class="button-row">
            <a class="button button-primary" href="/contact">
              Discuss Healthcare Integration
            </a>

            <a class="button button-secondary" href="/products">
              Explore Healthcare AI Products
            </a>
          </div>
        </div>

        <aside
          class="healthcare-summary"
          aria-labelledby="healthcare-focus-title"
        >
          <p id="healthcare-focus-title" class="panel-label">
            Healthcare Integration Focus
          </p>

          <ul>
            <li>
              <span class="marker" aria-hidden="true">01</span>
              <div>
                <strong>Healthcare Payer Integration</strong>
                <small>
                  Enrollment, claims, remittance, payments, and downstream
                  enterprise systems
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">02</span>
              <div>
                <strong>HIPAA X12 EDI</strong>
                <small>
                  834, 837 Professional, 837 Institutional, 835, and 820
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">03</span>
              <div>
                <strong>Integration Architecture</strong>
                <small>
                  Boomi orchestration, APIs, mapping, routing, monitoring, and
                  governance
                </small>
              </div>
            </li>

            <li>
              <span class="marker" aria-hidden="true">04</span>
              <div>
                <strong>Validation &amp; Automation</strong>
                <small>
                  Data quality, exception handling, operational support, and
                  AI-assisted analysis
                </small>
              </div>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Transaction Expertise -->
    <section class="section">
      <div class="container">
        <p class="eyebrow">Transaction Expertise</p>

        <h2>Healthcare data exchange across the payer lifecycle</h2>

        <p class="section-intro">
          My experience covers the major healthcare transactions used to
          exchange enrollment, claims, remittance, and payment information
          between health plans, providers, clearinghouses, employers, financial
          systems, and enterprise applications.
        </p>

        <div class="transaction-grid">
          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">834</span>
              <h3>Enrollment</h3>
            </div>
            <p>
              Member enrollment and maintenance, subscriber and dependent
              updates, eligibility synchronization, reconciliation, validation,
              and downstream integration.
            </p>
          </article>

          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">837</span>
              <h3>Professional Claims</h3>
            </div>
            <p>
              Professional claim intake, validation, transformation, routing,
              claim editing, exception handling, and payer system integration.
            </p>
          </article>

          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">837</span>
              <h3>Institutional Claims</h3>
            </div>
            <p>
              Institutional claim processing, structural validation, data
              transformation, routing, operational monitoring, and enterprise
              integration.
            </p>
          </article>

          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">835</span>
              <h3>Remittance Advice</h3>
            </div>
            <p>
              Electronic remittance processing, payment reconciliation,
              adjustment information, financial integration, and operational
              support.
            </p>
          </article>

          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">820</span>
              <h3>Premium Payments</h3>
            </div>
            <p>
              Premium payment processing, billing reconciliation, financial
              data exchange, validation, and integration with enterprise
              systems.
            </p>
          </article>

          <article class="card transaction-card">
            <div class="transaction-header">
              <span class="transaction-code" aria-hidden="true">API</span>
              <h3>Healthcare APIs</h3>
            </div>
            <p>
              Secure REST APIs, healthcare data services, interoperability,
              integration modernization, and API-enabled enterprise workflows.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Healthcare Integration Lifecycle -->
    <section class="section section-soft">
      <div class="container">
        <div class="section-heading-grid">
          <div>
            <p class="eyebrow">Healthcare Integration Lifecycle</p>
            <h2>
              Reliability and operational control across every transaction.
            </h2>
          </div>

          <p class="section-supporting-copy">
            Healthcare integration requires more than moving data between two
            systems. It requires validation, traceability, security, exception
            management, monitoring, and a clear understanding of downstream
            business impact.
          </p>
        </div>

        <div class="healthcare-process">
          <article class="card process-card">
            <div class="process-header">
              <span class="process-number" aria-hidden="true">01</span>
              <h3>Receive &amp; Secure</h3>
            </div>
            <p>
              Receive files, APIs, events, and partner transactions using
              secure, traceable enterprise integration patterns.
            </p>
          </article>

          <article class="card process-card">
            <div class="process-header">
              <span class="process-number" aria-hidden="true">02</span>
              <h3>Validate</h3>
            </div>
            <p>
              Validate transaction structure, required data, trading-partner
              rules, and healthcare-specific business requirements.
            </p>
          </article>

          <article class="card process-card">
            <div class="process-header">
              <span class="process-number" aria-hidden="true">03</span>
              <h3>Transform</h3>
            </div>
            <p>
              Map healthcare data into canonical, application-specific, or
              downstream enterprise formats.
            </p>
          </article>

          <article class="card process-card">
            <div class="process-header">
              <span class="process-number" aria-hidden="true">04</span>
              <h3>Route &amp; Orchestrate</h3>
            </div>
            <p>
              Apply routing logic, enrichment, business rules, workflow
              orchestration, and controlled downstream delivery.
            </p>
          </article>

          <article class="card process-card">
            <div class="process-header">
              <span class="process-number" aria-hidden="true">05</span>
              <h3>Monitor &amp; Recover</h3>
            </div>
            <p>
              Track transactions, manage exceptions, support retries, and
              provide operational visibility and recovery controls.
            </p>
          </article>
        </div>

        <article class="ai-enhancement">
          <div class="ai-enhancement-number" aria-hidden="true">AI</div>

          <div>
            <p class="panel-label">Intelligent Assistance Across the Lifecycle</p>
            <h3>Explain failures and accelerate resolution</h3>
            <p>
              AI-assisted analysis can explain validation failures, provide
              transaction and segment context, recommend corrective actions,
              and improve developer and operational support productivity.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Core Capabilities -->
    <section class="section">
      <div class="container">
        <p class="eyebrow">Core Capabilities</p>
        <h2>Beyond mapping and transaction processing</h2>

        <div class="detail-grid">
          <article class="card detail-card">
            <h3>EDI Mapping &amp; Transformation</h3>
            <p>
              Translation between HIPAA X12 transactions, canonical models,
              application formats, databases, APIs, and partner-specific
              structures.
            </p>
          </article>

          <article class="card detail-card">
            <h3>Validation &amp; Data Quality</h3>
            <p>
              Structural validation, required-field checks, business-rule
              validation, companion-guide alignment, and data-quality controls.
            </p>
          </article>

          <article class="card detail-card">
            <h3>Trading Partner Integration</h3>
            <p>
              Partner-specific configuration, routing, acknowledgements,
              onboarding, testing, certification, and production support.
            </p>
          </article>

          <article class="card detail-card">
            <h3>Error Handling</h3>
            <p>
              Exception categorization, retry patterns, notifications,
              reconciliation, auditability, and operational resolution
              workflows.
            </p>
          </article>

          <article class="card detail-card">
            <h3>Boomi Orchestration</h3>
            <p>
              Reusable Boomi processes, API services, event-driven patterns,
              integration governance, deployment strategy, and monitoring.
            </p>
          </article>

          <article class="card detail-card">
            <h3>Healthcare Modernization</h3>
            <p>
              Modernizing file-based healthcare exchange through enterprise
              APIs, reusable services, automation, and AI-assisted operational
              tooling.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Technology Stack -->
    <section class="section technology-section">
      <div class="container">
        <p class="eyebrow">Technology &amp; Standards</p>
        <h2>Healthcare integration technology ecosystem</h2>

        <div class="tech-stack" aria-label="Healthcare technologies and standards">
          <span>Boomi</span>
          <span>HIPAA X12</span>
          <span>834</span>
          <span>837P</span>
          <span>837I</span>
          <span>835</span>
          <span>820</span>
          <span>REST APIs</span>
          <span>FHIR</span>
          <span>SQL</span>
          <span>Validation</span>
          <span>Automation</span>
          <span>Agentic AI</span>
          <span>RAG</span>
        </div>
      </div>
    </section>

    <!-- Featured Product -->
    <section class="section section-soft">
      <div class="container product-feature">
        <div>
          <p class="eyebrow">Featured Healthcare Product</p>
          <h2>Healthcare EDI Intelligence Agent</h2>

          <p class="product-copy">
            An AI-powered healthcare EDI solution combining deterministic HIPAA
            X12 validation with Agentic AI and Retrieval-Augmented Generation.
            The product is designed to explain validation errors, identify root
            causes, recommend corrective actions, and improve developer and
            analyst productivity.
          </p>

          <div class="product-tags" aria-label="Product technologies">
            <span>Healthcare EDI</span>
            <span>HIPAA X12</span>
            <span>Python</span>
            <span>Pyx12</span>
            <span>ChromaDB</span>
            <span>Ollama</span>
            <span>Agentic AI</span>
          </div>

          <a class="text-link" href="/products">
            Explore the product
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <aside class="product-outcomes" aria-labelledby="designed-outcomes-title">
          <p id="designed-outcomes-title" class="panel-label">
            Designed Outcomes
          </p>

          <ul>
            <li>Clear explanations of complex EDI validation errors</li>
            <li>Transaction, segment, element, and loop-level context</li>
            <li>Recommended corrective actions</li>
            <li>Faster developer and analyst troubleshooting</li>
            <li>Reduced dependency on manual guide interpretation</li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="section healthcare-cta">
      <div class="container healthcare-cta-inner">
        <div>
          <p class="eyebrow">Let&rsquo;s Connect</p>
          <h2>
            Need help with healthcare integration, EDI, Boomi, or intelligent
            automation?
          </h2>
          <p>
            I am interested in architecture, solutioning, technical leadership,
            healthcare integration modernization, and AI-assisted enterprise
            integration opportunities.
          </p>
        </div>

        <div class="button-row">
          <a class="button button-primary" href="/contact">
            Start a Conversation
          </a>

          <a class="button button-secondary" href="/boomi">
            Explore Boomi Expertise
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .healthcare-hero {
    padding: 6rem 0 5rem;
    background:
      radial-gradient(
        circle at 85% 10%,
        rgba(22, 95, 184, 0.13),
        transparent 30%
      ),
      linear-gradient(180deg, #ffffff, #f4f8fc);
  }

  .healthcare-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.72fr);
    gap: 4rem;
    align-items: start;
  }

  .healthcare-hero h1 {
    max-width: 12ch;
    margin: 0.75rem 0 1.25rem;
    font-size: clamp(3rem, 5.5vw, 5rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .hero-lead {
    max-width: 44rem;
    margin: 0 0 1rem;
    color: var(--color-text);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 650;
    line-height: 1.45;
  }

  .hero-copy {
    max-width: 48rem;
    margin: 0 0 2rem;
    color: var(--color-text-body);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .healthcare-summary,
  .product-outcomes {
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--shadow-sm);
  }

  .panel-label {
    margin: 0 0 1.25rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .healthcare-summary ul,
  .product-outcomes ul {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .healthcare-summary li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .healthcare-summary li:first-child {
    padding-top: 0;
  }

  .healthcare-summary li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .healthcare-summary strong,
  .healthcare-summary small {
    display: block;
  }

  .healthcare-summary strong {
    color: var(--color-text);
    line-height: 1.35;
  }

  .healthcare-summary small {
    margin-top: 0.35rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .transaction-grid,
  .detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .transaction-card,
  .detail-card,
  .process-card {
    min-width: 0;
  }

  .transaction-header,
  .process-header {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .transaction-header h3,
  .process-header h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .transaction-code,
  .process-number {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    min-width: 2.7rem;
    height: 2.5rem;
    padding-inline: 0.45rem;
    border: 1px solid rgba(22, 95, 184, 0.14);
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 850;
    line-height: 1;
  }

  .transaction-card p,
  .detail-card p,
  .process-card p {
    margin: 0;
    color: var(--color-text-body);
    line-height: 1.7;
  }

  .section-heading-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.75fr);
    gap: 4rem;
    align-items: end;
  }

  .section-heading-grid h2 {
    max-width: 18ch;
  }

  .section-supporting-copy {
    margin: 0;
    color: var(--color-text-body);
    line-height: 1.8;
  }

  .healthcare-process {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .process-card {
    min-height: 15rem;
  }

  .process-card p {
    font-size: 0.93rem;
    line-height: 1.65;
  }

  .ai-enhancement {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-top: 1.25rem;
    padding: 1.75rem;
    border: 1px solid #b9d3ef;
    border-radius: var(--radius-md);
    background:
      linear-gradient(
        135deg,
        rgba(22, 95, 184, 0.09),
        rgba(255, 255, 255, 0.94)
      );
  }

  .ai-enhancement-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-sm);
    background: var(--color-primary);
    color: #ffffff;
    font-weight: 850;
  }

  .ai-enhancement .panel-label {
    margin-bottom: 0.5rem;
  }

  .ai-enhancement h3 {
    margin: 0 0 0.65rem;
  }

  .ai-enhancement p:last-child {
    max-width: 55rem;
    margin: 0;
    color: var(--color-text-body);
    line-height: 1.7;
  }

  .technology-section {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .product-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.7fr);
    gap: 4rem;
    align-items: center;
  }

  .product-copy {
    max-width: 48rem;
    margin-bottom: 0;
    line-height: 1.8;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 1.5rem 0 2rem;
  }

  .product-tags span {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .product-outcomes li {
    position: relative;
    padding: 0.9rem 0 0.9rem 1.15rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-body);
    line-height: 1.55;
  }

  .product-outcomes li::before {
    position: absolute;
    top: 1.45rem;
    left: 0;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--color-primary);
    content: "";
  }

  .product-outcomes li:first-child {
    padding-top: 0;
  }

  .product-outcomes li:first-child::before {
    top: 0.55rem;
  }

  .product-outcomes li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .text-link {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .text-link:hover {
    text-decoration: underline;
  }

  .healthcare-cta-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) auto;
    gap: 3rem;
    align-items: center;
    padding: 3rem;
    border-radius: var(--radius-lg);
    background: #102b4e;
    color: #ffffff;
  }

  .healthcare-cta h2,
  .healthcare-cta .eyebrow {
    color: #ffffff;
  }

  .healthcare-cta p {
    max-width: 50rem;
    color: #dce8f7;
  }

  .healthcare-cta .button-secondary {
    border-color: #ffffff;
    background: #ffffff;
    color: #102b4e;
  }

  .healthcare-cta .button-secondary:hover {
    border-color: #d9e6f5;
    background: #eaf2fb;
    color: #102b4e;
  }

  @media (max-width: 1100px) {
    .healthcare-process {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .healthcare-hero {
      padding: 4.5rem 0 4rem;
    }

    .healthcare-hero-grid,
    .section-heading-grid,
    .product-feature,
    .healthcare-cta-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .healthcare-summary,
    .product-outcomes {
      max-width: 42rem;
    }

    .transaction-grid,
    .detail-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .healthcare-cta-inner {
      padding: 2rem;
    }
  }

  @media (max-width: 640px) {
    .healthcare-hero {
      padding: 3.75rem 0 3.5rem;
    }

    .healthcare-hero h1 {
      font-size: clamp(2.65rem, 13vw, 4rem);
    }

    .hero-copy,
    .product-copy {
      font-size: 1rem;
    }

    .transaction-grid,
    .detail-grid,
    .healthcare-process {
      grid-template-columns: 1fr;
    }

    .healthcare-summary,
    .product-outcomes {
      padding: 1.3rem;
    }

    .process-card {
      min-height: auto;
    }

    .ai-enhancement {
      grid-template-columns: 1fr;
    }

    .healthcare-cta-inner {
      padding: 1.5rem;
    }
  }
</style>